# API Key to secure REST endpoints (required)
API_KEY="your_secret_api_key_here"

# Web server port (optional, default: 8787)
PORT=8787

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_DEFAULT_CHAT_ID="your_telegram_chat_id"

# ntfy notifications (optional)
NTFY_DEFAULT_TOPIC="isbn"
NTFY_DEFAULT_URL="https://ntfy.sh"
NTFY_AUTH_TOKEN="username:password" # auto-encoded to Basic base64, or use a raw token

# Generic webhook notifications (optional)
WEBHOOK_DEFAULT_URL="https://your-webhook-target.com"
